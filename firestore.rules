rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUserProfile(data) {
      return data.fullName is string && data.fullName.size() <= 100
          && data.collegeName is string && data.collegeName.size() <= 200
          && data.branch is string && data.branch.size() <= 50
          && data.currentSemester is int && data.currentSemester >= 1 && data.currentSemester <= 8
          && data.gradingScale in ['10-point', 'percentage']
          && (data.universityName == null || (data.universityName is string && data.universityName.size() <= 200));
    }

    function isValidSubject(data) {
      return data.name is string && data.name.size() <= 100
          && data.credits is int && data.credits >= 1 && data.credits <= 10
          && data.maxInternal is int && data.maxInternal >= 0
          && data.maxExternal is int && data.maxExternal >= 0
          && data.internalScore is int && data.internalScore >= 0
          && (data.externalScore == null || (data.externalScore is int && data.externalScore >= 0));
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() <= 200
          && data.teamSize is int && data.teamSize >= 1 && data.teamSize <= 10
          && data.domain is string && data.domain.size() <= 100
          && (data.milestones == null || (data.milestones is list && data.milestones.size() <= 50));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Profile document
      match /profile {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserProfile(incoming());
        allow update: if isOwner(userId) && isValidUserProfile(incoming()) 
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'collegeName', 'branch', 'currentSemester', 'gradingScale', 'universityName', 'updatedAt']));
        allow delete: if isOwner(userId);
      }

      // Subjects collection
      match /subjects/{subjectId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSubject(incoming());
        allow update: if isOwner(userId) && isValidSubject(incoming())
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'credits', 'maxInternal', 'maxExternal', 'internalScore', 'externalScore', 'targetGrade']));
        allow delete: if isOwner(userId);
      }

      // Project document
      match /project {
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProject(incoming());
        allow update: if isOwner(userId) && isValidProject(incoming())
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'teamSize', 'domain', 'hardware', 'startMonth', 'deadlineMonth', 'milestones']));
        allow delete: if isOwner(userId);
      }
    }
  }
}
